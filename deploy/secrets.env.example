# /etc/news-trading-bot/secrets.env
# 이 파일은 git에 커밋하지 마세요. 서버 로컬에서만 사용.
# 권한: chmod 640, owner root:ntb

# ─── Phase A (필수): Telegram ─────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 헬스체크 주기 (초). 기본 1800 = 30분.
HEARTBEAT_INTERVAL_SEC=1800

# ─── Phase B 이후 (지금은 비워둠): KIS ────────────────────────
# 환경 스위치
KIS_ENV=paper

# 공통
KIS_HTS_ID=

# 모의투자
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_ACCOUNT_NO=

# 실전 (Phase G에서 채움)
KIS_REAL_APP_KEY=
KIS_REAL_APP_SECRET=
KIS_REAL_ACCOUNT_NO=
